# =============================================================================
# Aletheia — example environment configuration
#
# Copy this file to `.env` and fill in the values. NEVER commit a real `.env`.
# Every service below has a genuinely free option; you supply your own keys.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers (free tiers — bring your own key)
# The runtime is provider-agnostic; set LLM_PROVIDER to pick the active one.
# -----------------------------------------------------------------------------
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq free tier: https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (pay-as-you-go, many models): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Active provider/model used by the agents (override per-agent later).
# Supported providers: "gemini" | "groq" | "openrouter"
LLM_PROVIDER=groq
LLM_MODEL=
# Fallback chain: primary → LLM_FALLBACK_PROVIDER → LLM_FALLBACK_PROVIDER_2
# Each must differ from the one before it. Leave blank to disable that tier.
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_PROVIDER_2=openrouter

# Embeddings for the corpus and queries. "local" (default) is an offline ONNX model
# (no key, reproducible); "gemini" reuses GEMINI_API_KEY. Leave EMBEDDING_MODEL unset
# to use the provider's default model.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=

# -----------------------------------------------------------------------------
# NCBI E-utilities (corpus ingestion only — optional, never needed to serve)
# An email (and optional free API key) identifies the client to NCBI and lifts the
# request-rate limit. Free key: https://www.ncbi.nlm.nih.gov/account/
# -----------------------------------------------------------------------------
NCBI_EMAIL=
NCBI_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL + pgvector (free locally via Docker; free cloud tiers exist)
# -----------------------------------------------------------------------------
POSTGRES_USER=aletheia
POSTGRES_PASSWORD=local-dev-only-change-me
POSTGRES_DB=aletheia
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aletheia:local-dev-only-change-me@localhost:5432/aletheia

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
# "plain" for humans (local default); "json" emits one structured object per line
# (with the request id) for the deployed demo's log collector.
LOG_FORMAT=plain
API_HOST=0.0.0.0
API_PORT=8000
# Intake scope guard: refuse non-medical queries and prompt-injection attempts before
# generating. Costs one short LLM classifier call per request; set false to disable.
SCOPE_GUARD_ENABLED=true
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000
# Public-demo protection (ADR-0007): per-IP token bucket over the /verify endpoints.
# 0 = dormant (local default). APP_ENV=production refuses to start when it is 0.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=10
# Read the client IP from X-Forwarded-For (last entry). Only enable behind a
# trusted platform proxy (HF Spaces/Render), never on a directly exposed port.
TRUST_PROXY_HEADERS=false
# Accounts (signup/login/profile/history, optional feature). JWT_SECRET signs session
# cookies; leaving it unset disables all /auth, /profile, and /history routes with a
# clear 503 rather than crashing. Generate one with `openssl rand -hex 32`.
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
# Required only to let users store their own provider key (bring-your-own-key). A
# Fernet key: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=
# Set false only for local http (non-TLS) development; the session cookie is
# httpOnly + Secure by default and must stay Secure behind real TLS.
COOKIE_SECURE=true
# Multimodal claim intake (/extract, ADR-0009). Uploads are processed in memory and
# never stored. Images are read by VISION_MODEL (reuses GEMINI_API_KEY); voice notes
# by TRANSCRIPTION_MODEL (reuses GROQ_API_KEY). MAX_UPLOAD_BYTES caps the upload body
# on /extract only; extracted text is truncated to EXTRACT_MAX_CHARS.
# VISION_MODEL: gemini-2.5-flash is the stable free-tier vision model; the newer
# gemini-3.5-flash is often 503 ("high demand") on the free tier.
MAX_UPLOAD_BYTES=10485760
VISION_MODEL=gemini-2.5-flash
TRANSCRIPTION_MODEL=whisper-large-v3-turbo
EXTRACT_MAX_CHARS=4000

# -----------------------------------------------------------------------------
# Frontend (Next.js) — only NEXT_PUBLIC_* values are exposed to the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
