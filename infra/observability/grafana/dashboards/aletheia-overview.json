{
  "uid": "aletheia-overview",
  "title": "Aletheia — service overview",
  "description": "Request rates, request latency, and per-stage pipeline durations from the backend's /metrics endpoint.",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["aletheia"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route and status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route, status) (rate(aletheia_http_requests_total[5m]))",
          "legendFormat": "{{route}} · {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request duration p95 by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(aletheia_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pipeline stage duration p50",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, stage) (rate(aletheia_pipeline_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pipeline stage duration p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(aletheia_pipeline_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}"
        }
      ]
    }
  ]
}
